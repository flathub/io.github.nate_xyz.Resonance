{
    "app-id" : "io.github.nate_xyz.Resonance",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command" : "resonance",
    "rename-appdata-file": "io.github.nate_xyz.Resonance.appdata.xml",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--filesystem=xdg-download:ro",
        "--filesystem=xdg-music:ro",
        "--filesystem=xdg-run/app/com.discordapp.Discord:create",
        "--filesystem=xdg-run/discord-ipc-0"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/rust-stable/bin"
    },
    "cleanup" : [
        "/share/man"
    ],
    "modules" : [
        "pypi-dependencies.json",
        {
            "name" : "resonance",
            "buildsystem" : "meson",
            "sources" : [
                "cargo-sources.json",
                {
                    "type" : "shell",
                    "commands" : [
                        "mkdir .cargo",
                        "cp cargo/config .cargo/"
                    ]
                },
                {
                    "type" : "git",
                    "url" : "https://github.com/nate-xyz/resonance",
                    "commit":"72cc1d2865be275519903b9d0918b3ac2fb7d288"
                },
                {
                    "type" : "patch",
                    "path":"fix_appdata.patch"
                }
            ]
        }
    ]
}
